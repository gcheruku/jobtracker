# Copy to .env (or export these) to override defaults.

# Defaults to the existing ../jobs.db. Point elsewhere or at Postgres if desired.
# JOBTRACKER_DATABASE_URL=sqlite:////absolute/path/to/jobs.db

# Comma-separated allowed origins, or * for any (default).
# JOBTRACKER_CORS_ORIGINS=http://localhost:5173,http://192.168.1.10:5173

# Where uploaded resume files are written.
# JOBTRACKER_RESUME_DIR=./uploads/resumes

# Set to enable real Claude analysis; without it the AI endpoint uses the
# offline heuristic stub.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Gmail job-alert ingestion + Gemini scoring ---
# Google Generative Language (Gemini) API key, used to extract jobs from alert
# emails and score them against the resume. Without it, ingestion still records
# jobs but skips extraction/scoring.
# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# Gmail OAuth files (defaults to backend/secrets/*). Token needs gmail.readonly.
# GMAIL_TOKEN_PATH=./secrets/token.json
# GMAIL_CREDENTIALS_PATH=./secrets/credentials.json
# GMAIL_LABEL=Job alerts

# Resume used for match scoring during ingestion.
# RESUME_DOCX_PATH=../Resume.docx

# Background fetch cadence (hours) and per-run safety cap on emails.
# INGEST_INTERVAL_HOURS=4
# INGEST_MAX_MESSAGES=60
# INGEST_RUN_ON_STARTUP=false
