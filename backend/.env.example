# Copy to .env (or export these) to override defaults.

# Defaults to the existing ../jobs.db. Point elsewhere or at Postgres if desired.
# JOBTRACKER_DATABASE_URL=sqlite:////absolute/path/to/jobs.db

# Comma-separated allowed origins, or * for any (default).
# JOBTRACKER_CORS_ORIGINS=http://localhost:5173,http://192.168.1.10:5173

# Where uploaded resume files are written.
# JOBTRACKER_RESUME_DIR=./uploads/resumes

# Set to enable real Claude analysis; without it the AI endpoint uses the
# offline heuristic stub.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
