# Copy to deploy/.env (for manual `docker compose` runs) or set these as env in
# the deploy workflow. The CI workflow sets DATA_DIR itself.

# NAS folder that holds all personal data (mounted into the backend at /data):
#   <DATA_DIR>/jobs.db
#   <DATA_DIR>/secrets/{credentials.json,token.json}
#   <DATA_DIR>/Resume.docx
#   <DATA_DIR>/.env          <-- app secrets (GOOGLE_API_KEY, etc.)
#   <DATA_DIR>/hf-cache/     <-- sentence-transformers model cache (auto-created)
DATA_DIR=/volume1/docker/jobtracker/data

# Host port to serve the web UI on (http://NAS-IP:WEB_PORT)
WEB_PORT=8080
